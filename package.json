{
  "name": "linear-worktree",
  "version": "0.0.1",
  "description": "Create git worktrees for Linear issues and launch Claude sessions",
  "keywords": [
    "cli",
    "git",
    "linear",
    "worktree"
  ],
  "homepage": "https://github.com/mblode/linear-worktree#readme",
  "bugs": {
    "url": "https://github.com/mblode/linear-worktree/issues"
  },
  "license": "MIT",
  "author": "Matthew Blode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mblode/linear-worktree.git"
  },
  "bin": {
    "linear-worktree": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "npm run build && changeset publish",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@types/node": "^22.19.11",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0",
    "ultracite": "^7.8.1",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
